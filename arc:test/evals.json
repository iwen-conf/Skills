{
  "version": "1.0.0",
  "skill": "arc:test",
  "defaults": {
    "timeout": 120,
    "working_dir": "."
  },
  "evals": [
    {
      "id": "detect_go_project",
      "title": "Detect Go project language and framework",
      "description": "Runs detect_lang.py on the Go fixture and verifies JSON output contains lang=go",
      "tags": ["ci", "detect"],
      "inputs": {
        "fixtures": [
          {
            "src": "arc:test/evals/fixtures/go_project",
            "dest": "fixtures/go_project"
          }
        ]
      },
      "workflow": {
        "steps": [
          {
            "name": "detect_lang",
            "run": "python3 scripts/detect_lang.py --project-path fixtures/go_project --json > fixtures/go_project/detect_result.json"
          }
        ]
      },
      "assertions": [
        {
          "type": "file_exists",
          "path": "fixtures/go_project/detect_result.json"
        },
        {
          "type": "json_parse",
          "path": "fixtures/go_project/detect_result.json"
        },
        {
          "type": "file_contains",
          "path": "fixtures/go_project/detect_result.json",
          "pattern": "\"lang\": \"go\""
        },
        {
          "type": "file_contains",
          "path": "fixtures/go_project/detect_result.json",
          "pattern": "\"framework\": \"testing\""
        }
      ]
    },
    {
      "id": "detect_python_project",
      "title": "Detect Python project language and framework",
      "description": "Runs detect_lang.py on the Python fixture and verifies JSON output contains lang=python",
      "tags": ["ci", "detect"],
      "inputs": {
        "fixtures": [
          {
            "src": "arc:test/evals/fixtures/python_project",
            "dest": "fixtures/python_project"
          }
        ]
      },
      "workflow": {
        "steps": [
          {
            "name": "detect_lang",
            "run": "python3 scripts/detect_lang.py --project-path fixtures/python_project --json > fixtures/python_project/detect_result.json"
          }
        ]
      },
      "assertions": [
        {
          "type": "file_exists",
          "path": "fixtures/python_project/detect_result.json"
        },
        {
          "type": "json_parse",
          "path": "fixtures/python_project/detect_result.json"
        },
        {
          "type": "file_contains",
          "path": "fixtures/python_project/detect_result.json",
          "pattern": "\"lang\": \"python\""
        },
        {
          "type": "file_contains",
          "path": "fixtures/python_project/detect_result.json",
          "pattern": "\"framework\": \"pytest\""
        }
      ]
    },
    {
      "id": "scaffold_go_dry_run",
      "title": "Scaffold Go tests in dry-run mode",
      "description": "Runs scaffold_tests.py with --dry-run on the Go fixture and verifies planned output",
      "tags": ["ci", "scaffold"],
      "inputs": {
        "fixtures": [
          {
            "src": "arc:test/evals/fixtures/go_project",
            "dest": "fixtures/go_project"
          }
        ]
      },
      "workflow": {
        "steps": [
          {
            "name": "scaffold_dry_run",
            "run": "python3 scripts/scaffold_tests.py --project-path fixtures/go_project --target fixtures/go_project/calc.go --test-types unit,boundary --dry-run > fixtures/go_project/scaffold_output.txt 2>&1",
            "expect_exit_code": 0
          }
        ]
      },
      "assertions": [
        {
          "type": "file_exists",
          "path": "fixtures/go_project/scaffold_output.txt"
        },
        {
          "type": "file_contains",
          "path": "fixtures/go_project/scaffold_output.txt",
          "pattern": "DRY-RUN"
        }
      ]
    },
    {
      "id": "validate_help_exits_clean",
      "title": "validate_tests.py --help exits cleanly",
      "description": "Verifies validate_tests.py --help does not crash",
      "tags": ["ci", "validate"],
      "inputs": {
        "fixtures": []
      },
      "workflow": {
        "steps": [
          {
            "name": "validate_help",
            "run": "python3 scripts/validate_tests.py --help > /dev/null 2>&1",
            "expect_exit_code": 0
          }
        ]
      },
      "assertions": []
    }
  ]
}
