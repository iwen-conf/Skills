{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arc-skills.dev/schemas/artifact-manifest.schema.json",
  "title": "Arc Artifact Manifest",
  "description": "Minimal reusable manifest protocol for generated skill artifacts",
  "type": "object",
  "required": ["schema_version", "producer_skill", "generated_at", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "producer_skill": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "name",
        "artifact_type",
        "path",
        "content_hash",
        "generated_at",
        "expires_at",
        "refresh_skill",
        "producer_skill"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "artifact_type": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "minLength": 1},
        "expires_at": {"type": "string", "minLength": 1},
        "refresh_skill": {"type": "string", "minLength": 1},
        "producer_skill": {"type": "string", "minLength": 1},
        "ttl_seconds": {"type": "integer", "minimum": 1},
        "consumers": {
          "type": "array",
          "items": {"type": "string"}
        },
        "refresh_command_hint": {"type": "string"}
      }
    }
  }
}
